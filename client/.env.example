# 배포 URL (리버스 프록시 환경에서 OAuth 콜백 리다이렉트에 사용)
# 로컬 개발: 설정 불필요 / 프로덕션: 실제 도메인 입력 (예: https://your-domain.com)
NEXT_PUBLIC_SITE_URL=

# Supabase (공개 키 - 클라이언트 사이드 사용)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Supabase (서버 전용 - API 라우트에서만 사용, 절대 NEXT_PUBLIC_ 접두사 붙이지 말 것)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Anthropic (서버 전용)
ANTHROPIC_API_KEY=
